# Frontend
VITE_API_BASE_URL=/api

# MySQL
MYSQL_USER=root
MYSQL_PASSWORD=change-me
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=rag_system

# Chroma / local runtime
CHROMA_PERSIST_DIR=./chroma_data
REBUILD_KNOWLEDGE_INDEX_ON_STARTUP=false
CHECKPOINTER_DB_PATH=./checkpointer.db

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseekv4flash

# Vision / image attachments
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_API_KEY=
VISION_MODEL=qwen3.6-plus
VISION_OSS_URL_EXPIRES_SECONDS=3600

# Text fallback
TEXT_FALLBACK_ENABLED=true
TEXT_FALLBACK_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
TEXT_FALLBACK_API_KEY=
TEXT_FALLBACK_MODEL=qwen3.6-plus

# Embedding
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024

# RAGAS
RAGAS_ENABLED=true
RAGAS_LLM_MODEL=deepseekv4flash
RAGAS_TIMEOUT_SECONDS=90
RAGAS_METRIC_TIMEOUT_SECONDS=30
RAGAS_MAX_CONTEXTS=3
RAGAS_MAX_CONTEXT_CHARS=1500
RAGAS_MAX_ANSWER_CHARS=2000

# Retrieval
RETRIEVAL_ROUTE_TOP_K=8
RETRIEVAL_RERANK_TOP_N=5

# Aliyun OSS
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_ENDPOINT=

# JWT hardening targets. backend/config.py should be adjusted before SECRET_KEY is honored from env.
SECRET_KEY=change-this-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
